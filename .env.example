# RedCAP API Configuration (required)
REDCAP_API_URL=https://your-redcap-instance.com/api/
REDCAP_API_TOKEN=your_redcap_api_token_here

# Application Settings
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Optional: Base URL for redirects (defaults to request origin)
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Optional: Contact info shown to participants
# NEXT_PUBLIC_CONTACT_NAME=Your Name
# NEXT_PUBLIC_CONTACT_PHONE=+45 12 34 56 78

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
